# Cisco FMC MCP Server Configuration

# Database Configuration
DATABASE_URL=postgresql://mcp_user:changeme@postgres:5432/fmc_mcp
DB_PASSWORD=changeme

# Security Configuration
EDIT_MODE_ENABLED=false
ENCRYPTION_KEY=generate-using-fernet-key-generation

# Server Configuration
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
LOG_LEVEL=INFO

# Session Configuration
SESSION_SECRET_KEY=generate-random-secret-key
SESSION_TIMEOUT_MINUTES=30

# Optional: MCP API Token for remote access security
# MCP_API_TOKEN=your-secure-token-here

# =============================================================================
# Cisco FMC Connection
# =============================================================================
# FMC credentials are managed per-device via the Web UI.
# These env vars seed the default device on first startup (optional).
#
# FMC_HOST_URL  - Base URL of your FMC instance (e.g. https://192.168.1.1)
# FMC_USERNAME  - FMC admin username
# FMC_PASSWORD  - FMC admin password
# FMC_VERIFY_SSL - Set to true to enforce TLS certificate verification
#
FMC_HOST_URL=https://192.168.1.1
FMC_USERNAME=admin
FMC_PASSWORD=
FMC_VERIFY_SSL=false

# =============================================================================
# SSL/TLS Configuration (HTTPS)
# =============================================================================

# Certificate generation settings
# CERT_DAYS       - Certificate validity period in days (default: 365)
# CERT_CN         - Certificate Common Name (default: fmc-mcp)
# CERT_ORG        - Certificate Organization (default: FMC MCP)
# CERT_SERVER_IP  - Your server's IP address (added to certificate SANs)
#                   IMPORTANT: Set this to your server's IP for browser access
CERT_DAYS=365
CERT_CN=fmc-mcp
CERT_ORG=FMC MCP
CERT_SERVER_IP=192.168.1.213

# =============================================================================
# Service URLs (HTTPS)
# =============================================================================

# PostgreSQL port (host-side mapping)
# Unique per stack: nexus=15432, catalyst=15433, fmc=15434
POSTGRES_PORT=15434

# Web API (FastAPI/MCP) HTTPS endpoint
# Unique per stack: nexus=8444, catalyst=8445, fmc=8446
# External access: https://YOUR_SERVER_IP:8446
WEB_API_PORT=8446

# Internal HTTP port (container-to-container, not exposed externally)
# Unique per stack: nexus=7100, catalyst=7101, fmc=7102
INTERNAL_HTTP_PORT=7102

# Web UI (Next.js) HTTPS endpoint
# Unique per stack: nexus=7443, catalyst=7444, fmc=7445
# External access: https://YOUR_SERVER_IP:7445
WEB_UI_PORT=7445

# =============================================================================
# Notes
# =============================================================================
#
# FMC device credentials are managed via the Web UI.
# Configure devices at https://YOUR_SERVER_IP:7445/clusters after starting.
#
# MCP SSE endpoint for Claude Desktop:
#   https://YOUR_SERVER_IP:8446/mcp/sse
#
# Self-signed certificates will generate browser warnings on first access.
# Accept the certificate to continue.
#
# To regenerate certificates:
#   1. docker compose down
#   2. docker volume rm fmc-mcp-certs
#   3. docker compose up --build
#
# FMC Auth flow:
#   POST /api/fmc_platform/v1/auth/generatetoken (Basic auth)
#   -> X-auth-access-token header used for all subsequent requests
#   -> DOMAIN_UUID header identifies the default domain
